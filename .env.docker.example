# ============================================================
# Software Guard Docker 部署环境变量配置
# 复制此文件为 .env.docker 并修改配置后使用
# ============================================================

# ---------- 数据库配置 ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<请修改为强密码，至少16位>
POSTGRES_DB=software_guard
DB_PORT=5432

# ---------- 应用配置 ----------
APP_PORT=8000

# ---------- JWT 密钥（必须修改！） ----------
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<请替换为随机生成的密钥>

# ---------- 初始管理员账号（首次启动时创建） ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<请修改为强密码>
ADMIN_EMAIL=admin@company.com
